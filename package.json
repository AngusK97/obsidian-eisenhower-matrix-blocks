{
	"name": "obsidian-quadrant-tasks",
	"version": "1.0.0",
	"description": "A focused four-quadrant task board with a filterable completion history for Obsidian.",
	"private": true,
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/AngusK97/obsidian-quadrant-tasks.git"
	},
	"scripts": {
		"build": "esbuild src/main.js --bundle --external:obsidian --platform=node --format=cjs --target=es2018 --outfile=main.js",
		"test": "node --test tests/*.test.js",
		"check": "node --check src/core.js && node --check src/main.js",
		"verify": "npm run check && npm run build && npm test"
	},
	"devDependencies": {
		"esbuild": "0.25.6"
	}
}
